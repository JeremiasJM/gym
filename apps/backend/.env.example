# ============================================
# CEFIDE — Variables de Entorno
# ============================================
# Copiar este archivo a .env y completar los valores
# cp .env.example .env

# --- Base de datos ---
DATABASE_URL=postgresql://cefide:cefide_dev@localhost:5432/cefide

# --- Autenticacion ---
# En produccion generar con: openssl rand -hex 64
JWT_SECRET=dev-secret-cambiar-en-produccion
JWT_EXPIRES_IN=7d

# --- Usuario ADMIN inicial ---
# Se crea/actualiza automaticamente al arrancar la app (idempotente).
# Si no se definen ambas, no se crea ningun admin.
ADMIN_EMAIL=admin@cefide.com
ADMIN_PASSWORD=cambiar-en-produccion

# --- Aplicacion ---
PORT=3000
NODE_ENV=development
# URL del frontend para CORS. En produccion: https://cefide.fullmindtech.com
CORS_ORIGIN=http://localhost:5173

# --- Molinete (servicio local en PC del gym) ---
COM_PORT_MOLINETE_1=COM1
COM_PORT_MOLINETE_2=COM2
COM_SERVICE_URL_1=http://localhost:3001
COM_SERVICE_URL_2=http://localhost:3002
# Duracion del pulso de apertura en ms (segun spec PCA150, no cambiar)
COM_PULSE_MS=500

# --- Dokploy / Traefik (solo produccion) ---
# Dominio donde Traefik expone la API
# API_DOMAIN=api-cefide.fullmindtech.com

# --- Config por defecto del sistema ---
# Clases de gracia: cuantas clases puede tomar un alumno sin pagar al inicio del mes
DEFAULT_CLASES_GRACIA=2
# Dia del mes limite para regularizar el pago
DEFAULT_DIA_VENCIMIENTO=5
