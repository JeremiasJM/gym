generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Frecuencia {
  UNA_VEZ
  DOS_VECES
  TRES_VECES
  LIBRE
}

enum TipoPago {
  PAGO
  ANULACION
}

enum Rol {
  ADMIN
  PROFESOR
}

enum EstadoIngreso {
  VERDE
  AMARILLO
  ROJO
}

model Actividad {
  id            String                 @id @default(cuid())
  nombre        String                 @unique
  activo        Boolean                @default(true)
  inscripciones InscripcionActividad[]
  profesores    Profesor[]             @relation("ProfesorActividades")
  creadoEn      DateTime               @default(now())
}

model Alumno {
  id            String                 @id @default(cuid())
  dni           String                 @unique
  nombre        String
  apellido      String
  activo        Boolean                @default(true)
  inscripciones InscripcionActividad[]
  ingresos      Ingreso[]
  pagos         Pago[]
  creadoEn      DateTime               @default(now())
  actualizadoEn DateTime               @updatedAt

  @@index([dni])
}

model InscripcionActividad {
  id           String     @id @default(cuid())
  alumnoId     String
  alumno       Alumno     @relation(fields: [alumnoId], references: [id])
  actividadId  String
  actividad    Actividad  @relation(fields: [actividadId], references: [id])
  frecuencia   Frecuencia
  clasesTotal  Int
  clasesUsadas Int        @default(0)
  pagado       Boolean    @default(false)
  fechaPago    DateTime?
  pagos        Pago[]
  ingresos     Ingreso[]
  creadoEn     DateTime   @default(now())

  @@unique([alumnoId, actividadId])
  @@index([alumnoId])
  @@index([actividadId])
}

model Profesor {
  id          String      @id @default(cuid())
  dni         String      @unique
  nombre      String
  apellido    String
  usuario     Usuario?
  actividades Actividad[] @relation("ProfesorActividades")
}

model Usuario {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  rol        Rol       @default(PROFESOR)
  profesorId String?   @unique
  profesor   Profesor? @relation(fields: [profesorId], references: [id])
  creadoEn   DateTime  @default(now())
}

model Ingreso {
  id            String                @id @default(cuid())
  alumnoId      String
  alumno        Alumno                @relation(fields: [alumnoId], references: [id])
  inscripcionId String?
  inscripcion   InscripcionActividad? @relation(fields: [inscripcionId], references: [id])
  fechaHora     DateTime              @default(now())
  estado        EstadoIngreso
  molinete      Int                   @default(1)

  @@index([alumnoId])
  @@index([inscripcionId])
  @@index([fechaHora])
}

model Pago {
  id            String                @id @default(cuid())
  alumnoId      String
  alumno        Alumno                @relation(fields: [alumnoId], references: [id])
  inscripcionId String?
  inscripcion   InscripcionActividad? @relation(fields: [inscripcionId], references: [id])
  tipo          TipoPago
  fecha         DateTime              @default(now())
  nota          String?

  @@index([alumnoId])
  @@index([inscripcionId])
  @@index([fecha])
}

model ConfigSistema {
  id              String @id @default("global")
  clasesGracia    Int    @default(2)
  diaVencimiento  Int    @default(5)
  clasesUnaVez    Int    @default(5)
  clasesDosVeces  Int    @default(9)
  clasesTresVeces Int    @default(13)
  clasesLibre     Int    @default(30)
  tiempoVerde     Int    @default(4)
  tiempoAmarillo  Int    @default(5)
  tiempoRojo      Int    @default(6)
}
